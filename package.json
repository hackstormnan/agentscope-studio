{
  "name": "agentscope-studio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server/api/server.js",
    "dev": "ts-node src/server/api/server.ts",
    "dev:server": "ts-node src/server/api/server.ts",
    "cli": "ts-node src/cli/index.ts",
    "test": "ts-node tests/run.ts",
    "test:integration": "ts-node tests/run.ts",
    "test:smoke": "ts-node tests/run.ts",
    "ci:smoke": "ts-node tests/run.ts",
    "sanity:post": "ts-node scripts/post-trace.ts",
    "sanity:get": "ts-node scripts/get-traces.ts"
  },
  "dependencies": {
    "express": "^4.19.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.19.37",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
